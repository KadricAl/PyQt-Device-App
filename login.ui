   <string notr="true">
/* Base background and text colors */
QWidget {
    background-color: #2c3e50; /* Dark Slate Gray */
    color: #ecf0f1; /* Light Gray */
    font-family: 'Segoe UI', sans-serif;
}

/* Styling for LineEdits (username/password fields) */
QLineEdit {
    background-color: #34495e; /* Wet Asphalt */
    border: 1px solid #8e44ad; /* Wisteria Purple */
    border-radius: 8px;
    padding: 10px;
    font-size: 14px;
}
QLineEdit:focus {
    border-color: #9b59b6; /* Amethyst Purple */
    background-color: #4a637f;
}

/* Styling for the ComboBox (role selection) */
QComboBox {
    background-color: #34495e;
    border: 1px solid #8e44ad;
    border-radius: 8px;
    padding: 10px;
    selection-background-color: #27ae60; /* Nephritis Green */
}
QComboBox::drop-down {
    border: none;
}
QComboBox QAbstractItemView { /* Style for the dropdown list */
    background-color: #34495e;
    selection-background-color: #27ae60;
    color: #ecf0f1;
}

/* Primary Button Styling (Login) */
QPushButton#login_button {
    background-color: #27ae60; /* Nephritis Green */
    border: none;
    border-radius: 8px;
    padding: 12px;
    font-size: 16px;
    font-weight: bold;
}
QPushButton#login_button:hover {
    background-color: #2ecc71; /* Emerald Green */
}
QPushButton#login_button:pressed {
    background-color: #25a25a;
}

/* Secondary Button Styling (Register) */
QPushButton#register_button {
    background-color: transparent;
    border: none;
    color: #9b59b6; /* Amethyst Purple */
    font-size: 12px;
    text-decoration: underline;
}
QPushButton#register_button:hover {
    color: #8e44ad; /* Wisteria Purple */
}

/* Error Message Label */
QLabel#error_label {
    color: #e74c3c; /* Alizarin Red */
    font-size: 12px;
    font-weight: bold;
}

/* Title Label */
QLabel#title_label {
    font-size: 28px;
    font-weight: bold;
    color: #ecf0f1;
    qproperty-alignment: 'AlignCenter';
}
