   <string notr="true">
/* Base background and text colors */
QWidget {
    background-color: #2c3e50; /* Dark Slate Gray */
    color: #ecf0f1; /* Light Gray */
    font-family: 'Segoe UI', sans-serif;
}

/* Styling for LineEdits */
QLineEdit {
    background-color: #34495e; /* Wet Asphalt */
    border: 1px solid #8e44ad; /* Wisteria Purple */
    border-radius: 8px;
    padding: 10px;
    font-size: 14px;
}
QLineEdit:focus {
    border-color: #9b59b6; /* Amethyst Purple */
    background-color: #4a637f;
}

/* Styling for the ComboBox */
QComboBox {
    background-color: #34495e;
    border: 1px solid #8e44ad;
    border-radius: 8px;
    padding: 10px;
    selection-background-color: #27ae60; /* Nephritis Green */
}
QComboBox::drop-down {
    border: none;
}
QComboBox QAbstractItemView {
    background-color: #34495e;
    selection-background-color: #27ae60;
    color: #ecf0f1;
}

/* Primary Button Styling (Register) */
QPushButton#register_button {
    background-color: #9b59b6; /* Amethyst Purple */
    border: none;
    border-radius: 8px;
    padding: 12px;
    font-size: 16px;
    font-weight: bold;
}
QPushButton#register_button:hover {
    background-color: #8e44ad; /* Wisteria Purple */
}
QPushButton#register_button:pressed {
    background-color: #823db4;
}

/* Message Label */
QLabel#message_label {
    color: #2ecc71; /* Emerald Green for success */
    font-size: 12px;
    font-weight: bold;
}

/* Title Label */
QLabel#title_label {
    font-size: 28px;
    font-weight: bold;
    color: #ecf0f1;
    qproperty-alignment: 'AlignCenter';
}
